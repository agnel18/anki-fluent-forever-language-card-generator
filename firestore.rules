rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // All Firestore access goes through the Firebase Admin SDK (server-side),
    // which bypasses these rules entirely. Deny all direct client access
    // to protect user data (including encrypted API keys).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}